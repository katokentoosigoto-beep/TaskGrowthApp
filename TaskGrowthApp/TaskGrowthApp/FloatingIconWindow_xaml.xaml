<Window x:Class="TaskGrowthApp.FloatingIconWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="88" Height="88"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <Storyboard x:Key="FloatLoop" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation
                Storyboard.TargetName="FloatTranslate"
                Storyboard.TargetProperty="Y"
                From="-2" To="2"
                Duration="0:0:2.0">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="EmergencyPulse" RepeatBehavior="Forever" AutoReverse="True">
            <ColorAnimation
                Storyboard.TargetName="RingBrush"
                Storyboard.TargetProperty="Color"
                From="#CC3333" To="#FF6666"
                Duration="0:0:0.6">
                <ColorAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </ColorAnimation.EasingFunction>
            </ColorAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid Margin="0,4,0,0">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="FloatTranslate"/>
        </Grid.RenderTransform>

        <!-- 外側の光輪 -->
        <Ellipse Width="78" Height="78"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center">
            <Ellipse.Fill>
                <SolidColorBrush x:Name="RingBrush" Color="#33444444"/>
            </Ellipse.Fill>
        </Ellipse>

        <!-- メイン丸 -->
        <Ellipse x:Name="MainCircle"
                 Width="66" Height="66"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center">
            <Ellipse.Fill>
                <SolidColorBrush Color="#EE111111"/>
            </Ellipse.Fill>
            <Ellipse.Stroke>
                <SolidColorBrush x:Name="BorderBrush" Color="#88888888"/>
            </Ellipse.Stroke>
            <Ellipse.StrokeThickness>1.5</Ellipse.StrokeThickness>
        </Ellipse>

        <!-- キャラクター動画（約1.5倍） -->
        <MediaElement x:Name="CharVideo"
                      Source="pack://siteoforigin:,,,/Resources/character.mp4"
                      Width="56" Height="56"
                      Stretch="Uniform"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Stop"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Margin="0,0,0,2">
            <MediaElement.Clip>
                <EllipseGeometry Center="28,28" RadiusX="28" RadiusY="28"/>
            </MediaElement.Clip>
        </MediaElement>

        <!-- レベル -->
        <Border x:Name="LevelBadge"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,6"
                Background="#CC000000"
                BorderBrush="#CC9966"
                BorderThickness="1"
                CornerRadius="3"
                Padding="3,0">
            <TextBlock x:Name="LevelText"
                       Text="Lv.1"
                       FontFamily="Consolas"
                       FontSize="10"
                       FontWeight="Bold"
                       Foreground="#CC9966"/>
        </Border>

        <!-- 緊急バッジ -->
        <Ellipse x:Name="EmergencyDot"
                 Width="14" Height="14"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Top"
                 Margin="0,4,4,0"
                 Fill="#CC3333"
                 Visibility="Collapsed"/>

        <TextBlock x:Name="EmergencyMark"
                   Text="!"
                   FontFamily="Consolas"
                   FontSize="10"
                   FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Margin="0,4,8,0"
                   Visibility="Collapsed"/>

        <!-- クリック領域 -->
        <Ellipse Width="78" Height="78"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Fill="Transparent"
                 Cursor="Hand"
                 MouseLeftButtonDown="OnIconClick"
                 MouseRightButtonDown="OnIconRightClick"
                 ToolTip="クリックで展開 / 右クリックで終了"/>
    </Grid>
</Window>