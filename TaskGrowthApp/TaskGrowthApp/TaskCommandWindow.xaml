<Window x:Class="TaskGrowthApp.Views.TaskCommandWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="コマンド"
        Width="200"
        Height="180"
        WindowStyle="None"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Background="Black"
        FontFamily="Consolas"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border BorderBrush="White" BorderThickness="2" Padding="12">
        <Grid>
            <!-- 罰ボタン（右上×） -->
            <Button Width="24" Height="24"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Content="×"
                    Click="OnCloseWindow"
                    Background="Black"
                    BorderBrush="White"
                    BorderThickness="1">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <StackPanel Margin="0,28,0,0">
                <TextBlock Text="どうする？"
                           Foreground="White"
                           FontSize="14"
                           Margin="0,0,0,12"
                           HorizontalAlignment="Center"/>

                <!-- たおすボタン -->
                <Grid x:Name="AttackButtonGrid" Height="28" Margin="0,0,0,8" Background="Transparent"
                      MouseLeftButtonDown="AttackButtonGrid_MouseLeftButtonDown">
                    <Border Background="Black"
                            BorderBrush="White"
                            BorderThickness="1"
                            CornerRadius="2"/>
                    <TextBlock Text="たおす"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="AttackCursor" Text="▶"
                               Foreground="White"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               Margin="2,0,0,0"
                               Visibility="Collapsed"/>
                </Grid>

                <!-- すてるボタン -->
                <Grid x:Name="DeleteButtonGrid" Height="28" Background="Transparent"
                      MouseLeftButtonDown="DeleteButtonGrid_MouseLeftButtonDown">
                    <Border Background="Black"
                            BorderBrush="White"
                            BorderThickness="1"
                            CornerRadius="2"/>
                    <TextBlock Text="すてる"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="DeleteCursor" Text="▶"
                               Foreground="White"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               Margin="2,0,0,0"
                               Visibility="Collapsed"/>
                </Grid>

            </StackPanel>
        </Grid>
    </Border>
</Window>
