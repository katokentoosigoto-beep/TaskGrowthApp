<Window x:Class="TaskGrowthApp.Views.DueDatePopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="230"
        Height="260"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#111111"
        FontFamily="Consolas"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border BorderBrush="#FFFFFF" BorderThickness="2" Padding="10">
        <StackPanel>

            <!-- ===== タイトルバー ===== -->
            <Grid Margin="0,0,0,8">
                <TextBlock Text="📅  期限を設定"
                           Foreground="White"
                           FontSize="11"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <Button Content="×"
                        Width="20" Height="20"
                        HorizontalAlignment="Right"
                        Foreground="White"
                        Background="#333333"
                        BorderBrush="#666666"
                        Click="OnClose"/>
            </Grid>

            <!-- ===== 月ナビゲーション ===== -->
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="28"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="PrevMonthBtn"
                        Grid.Column="0"
                        Content="◀"
                        FontSize="10"
                        Height="22"
                        Foreground="White"
                        Background="#2a2a2a"
                        BorderBrush="#555555"
                        Click="OnPrevMonth"/>

                <TextBlock x:Name="MonthLabel"
                           Grid.Column="1"
                           FontSize="12"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <Button x:Name="NextMonthBtn"
                        Grid.Column="2"
                        Content="▶"
                        FontSize="10"
                        Height="22"
                        Foreground="White"
                        Background="#2a2a2a"
                        BorderBrush="#555555"
                        Click="OnNextMonth"/>
            </Grid>

            <!-- ===== 曜日ヘッダー ===== -->
            <UniformGrid x:Name="WeekHeader"
                         Rows="1" Columns="7"
                         Margin="0,0,0,2"/>

            <!-- ===== 日付グリッド（6週 × 7列） ===== -->
            <UniformGrid x:Name="DayGrid"
                         Rows="6" Columns="7"/>

            <!-- ===== クリア / 今日ボタン ===== -->
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="今日"
                        Height="22" FontSize="10"
                        Foreground="Lime"
                        Background="#1a2a1a"
                        BorderBrush="Lime"
                        Click="OnToday"/>

                <Button Grid.Column="2"
                        Content="期限なし"
                        Height="22" FontSize="10"
                        Foreground="#AAAAAA"
                        Background="#222222"
                        BorderBrush="#555555"
                        Click="OnClear"/>
            </Grid>

        </StackPanel>
    </Border>
</Window>
