<Window x:Class="TaskGrowthApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TaskGrowthApp"
        Width="300"
        Height="370"
        MinHeight="240"
        Background="Black"
        FontFamily="Consolas"
        WindowStyle="None"
        ResizeMode="NoResize"
        Loaded="OnWindowLoaded"
        Topmost="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>

        <Storyboard x:Key="DueTodayBlink" RepeatBehavior="Forever" AutoReverse="True">
            <ColorAnimation
        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
        From="#FF4444"
        To="#550000"
        Duration="0:0:0.7">
                <ColorAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </ColorAnimation.EasingFunction>
            </ColorAnimation>
        </Storyboard>

        <Storyboard x:Key="DropAndBounce">
            <DoubleAnimation Storyboard.TargetName="CharacterRoot" Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.15"/>
            <DoubleAnimation Storyboard.TargetName="DropY"         Storyboard.TargetProperty="Y"       From="-40" To="0" BeginTime="0:0:0.15" Duration="0:0:0.35" AccelerationRatio="0.3"/>
            <DoubleAnimation Storyboard.TargetName="CharacterRoot" Storyboard.TargetProperty="Opacity" From="0" To="1" BeginTime="0:0:0.15" Duration="0:0:0.05"/>
            <DoubleAnimation Storyboard.TargetName="BounceScale"   Storyboard.TargetProperty="ScaleY"  From="1" To="0.85" BeginTime="0:0:0.5" Duration="0:0:0.08" AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="DropY"         Storyboard.TargetProperty="Y"       From="0" To="-6" BeginTime="0:0:0.58" Duration="0:0:0.12" AutoReverse="True"/>
        </Storyboard>

        <local:EmergencyBackgroundConverter x:Key="EmergencyBackgroundConverter"/>
        <local:EmergencyForegroundConverter x:Key="EmergencyForegroundConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background"         Value="#1e1e1e"/>
            <Setter Property="Foreground"         Value="White"/>
            <Setter Property="BorderBrush"        Value="#666666"/>
            <Setter Property="BorderThickness"    Value="1"/>
            <Setter Property="Padding"            Value="4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="2"/>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="5,0,20,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <TextBlock Text="▾"
                                       Foreground="White"
                                       FontSize="10"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0"
                                       IsHitTestVisible="False"/>
                            <ToggleButton Focusable="False"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Opacity="0"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder"
                                        Background="#1e1e1e"
                                        BorderBrush="#888888"
                                        BorderThickness="1"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="200">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background"      Value="#1e1e1e"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Padding"         Value="6,3"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#333333"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#444400"/>
                                <Setter Property="Foreground" Value="Gold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= Status ================= -->
        <Border Grid.Row="0" BorderBrush="White" BorderThickness="2" Padding="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Canvas x:Name="EmergencyCanvas" Grid.Row="0" Height="16" ClipToBounds="True" Visibility="Collapsed">
                    <TextBlock x:Name="EmergencyText" Text="緊急クエスト 出現中！"
                               FontSize="10" FontWeight="Bold" Foreground="Red"/>
                </Canvas>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid x:Name="CharacterRoot" Width="80" Height="80" RenderTransformOrigin="0.5,1.0">
                        <Grid.RenderTransform>
                            <TransformGroup>
                                <TranslateTransform x:Name="DropY"/>
                                <ScaleTransform    x:Name="BounceScale"/>
                            </TransformGroup>
                        </Grid.RenderTransform>

                        <!-- ★ Image → MediaElement に変更 -->
                        <MediaElement x:Name="CharacterVideo"
                                      Source="pack://siteoforigin:,,,/Resources/character.mp4"
                                      Width="80" Height="80"
                                      Stretch="Uniform"
                                      LoadedBehavior="Manual"
                                      UnloadedBehavior="Stop"
                                      MediaEnded="CharacterVideo_MediaEnded"/>

                        <TextBlock x:Name="LevelText" FontSize="10" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                    </Grid>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                        <TextBlock x:Name="ExpLabel" FontSize="8" Foreground="#888888" Margin="0,0,0,2"/>
                        <ProgressBar x:Name="ExpBar" Height="8" Foreground="Lime"
                                     Background="#222222" BorderBrush="#555555"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="_" Width="18" Height="18" Foreground="White" Background="Black" BorderBrush="White" Click="OnMinimize"/>
                            <Button Content="×" Width="18" Height="18" Foreground="White" Background="Black" BorderBrush="White" Click="OnClose"/>
                        </StackPanel>
                        <TextBlock x:Name="CoinText" FontSize="10" Foreground="Gold"
                                   HorizontalAlignment="Right" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ================= Add Task：1行目 ================= -->
        <Border Grid.Row="1" Margin="0,5,0,0" BorderBrush="White" BorderThickness="2" Padding="4,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="52"/>
                    <ColumnDefinition Width="26"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="TaskNameBox"
                         Grid.Column="0"
                         Height="20"
                         FontSize="10"
                         Background="#1a1a1a"
                         Foreground="White"
                         CaretBrush="White"
                         BorderBrush="#555555"
                         VerticalContentAlignment="Center"
                         KeyDown="TaskNameBox_KeyDown"/>

                <ComboBox x:Name="PriorityBox"
                          Grid.Column="1"
                          Height="20"
                          FontSize="10"
                          SelectedIndex="1"
                          Margin="4,0"
                          Style="{StaticResource DarkComboBox}">
                    <ComboBoxItem Style="{StaticResource DarkComboBoxItem}">
                        <TextBlock Text="低" Foreground="#55FF55"/>
                    </ComboBoxItem>
                    <ComboBoxItem Style="{StaticResource DarkComboBoxItem}">
                        <TextBlock Text="中" Foreground="Yellow"/>
                    </ComboBoxItem>
                    <ComboBoxItem Style="{StaticResource DarkComboBoxItem}">
                        <TextBlock Text="高" Foreground="#FF6666"/>
                    </ComboBoxItem>
                    <ComboBoxItem Style="{StaticResource DarkComboBoxItem}">
                        <TextBlock Text="緊急" Foreground="White" FontWeight="Bold"/>
                    </ComboBoxItem>
                </ComboBox>

                <Button Content="＋"
                        Grid.Column="2"
                        Height="20"
                        FontSize="11"
                        Foreground="White"
                        Background="#1a3a1a"
                        BorderBrush="Lime"
                        Click="OnAddTask"/>
            </Grid>
        </Border>

        <!-- ================= Add Task：2行目（期限設定） ================= -->
        <Border Grid.Row="2" Margin="0,2,0,4"
                BorderBrush="#555555" BorderThickness="1,1,1,1"
                Background="#0d0d0d" Padding="5,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="期限"
                           Grid.Column="0"
                           FontSize="10"
                           Foreground="#888888"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>

                <Border Grid.Column="1"
                        Background="#1a1a1a"
                        BorderBrush="#444444"
                        BorderThickness="1"
                        CornerRadius="2"
                        Padding="5,1">
                    <TextBlock x:Name="SelectedDueDateText"
                               FontSize="10"
                               Foreground="#666666"
                               VerticalAlignment="Center"
                               Text="未設定"/>
                </Border>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="5,0,0,0">
                    <Button x:Name="DueDateButton"
                            Content="📅 選択"
                            Height="20"
                            Padding="5,0"
                            FontSize="10"
                            Foreground="White"
                            Background="#1a2a3a"
                            BorderBrush="#4488aa"
                            Click="OnOpenDueDatePopup"/>
                    <Button x:Name="DueDateClearButton"
                            Content="✕"
                            Width="20" Height="20"
                            FontSize="10"
                            Foreground="#888888"
                            Background="#2a1a1a"
                            BorderBrush="#663333"
                            Margin="3,0,0,0"
                            Visibility="Collapsed"
                            Click="OnClearDueDate"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ================= Task List ================= -->
        <ListBox x:Name="TaskList"
                 Grid.Row="3"
                 Background="Black"
                 BorderBrush="White"
                 BorderThickness="2"
                 Foreground="White"
                 MouseDoubleClick="OnTaskCommand"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 HorizontalContentAlignment="Stretch">

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Height" Value="24"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ControlTemplate.Resources>
                                    <Storyboard x:Key="DueTodayBlink" RepeatBehavior="Forever" AutoReverse="True">
                                        <ColorAnimation
                                Storyboard.TargetName="TaskBorder"
                                Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                From="#FF4444"
                                To="#550000"
                                Duration="0:0:0.7">
                                            <ColorAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut"/>
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                    </Storyboard>
                                </ControlTemplate.Resources>

                                <Border x:Name="TaskBorder"
                            Background="{Binding Priority, Converter={StaticResource EmergencyBackgroundConverter}}"
                            BorderThickness="0,0,0,1">
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="#333333"/>
                                    </Border.BorderBrush>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="14"/>
                                            <ColumnDefinition Width="34"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock x:Name="Cursor" Text="➤" FontSize="10" Foreground="Gold"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Visibility="Collapsed"/>

                                        <TextBlock Grid.Column="1"
                                       Text="{Binding PriorityText}"
                                       FontSize="10"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{Binding Priority, Converter={StaticResource EmergencyForegroundConverter}}"/>

                                        <TextBlock Grid.Column="2"
                                       Text="{Binding Name}"
                                       FontSize="10" Foreground="White"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="4,0"/>

                                        <TextBlock Grid.Column="3"
                                       Text="⚠"
                                       FontSize="8"
                                       Foreground="Orange"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Visibility="{Binding DueWarningVisible, Converter={StaticResource BoolToVis}}"/>

                                        <TextBlock Grid.Column="4"
                                       Text="{Binding DueDateText}"
                                       FontSize="8"
                                       Foreground="{Binding DueDateColor}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,3,0"/>
                                    </Grid>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Cursor" Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="TaskBorder" Property="BorderBrush" Value="Gold"/>
                                        <Setter TargetName="TaskBorder" Property="BorderThickness" Value="1"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TaskBorder" Property="BorderBrush" Value="#666666"/>
                                        <Setter TargetName="TaskBorder" Property="BorderThickness" Value="1"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsDueToday}" Value="True">
                                        <Setter TargetName="TaskBorder" Property="BorderBrush" Value="Red"/>
                                        <Setter TargetName="TaskBorder" Property="BorderThickness" Value="2"/>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="BlinkSB"
                                                 Storyboard="{StaticResource DueTodayBlink}"/>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="BlinkSB"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

        </ListBox>
    </Grid>
</Window>
